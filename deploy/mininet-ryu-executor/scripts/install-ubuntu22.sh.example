#!/usr/bin/env bash
set -euo pipefail

# Example only. Review before running on your Ubuntu 22.04 host.
# Do not add credentials, SSH keys, tokens, or server addresses here.

sudo apt-get update
sudo apt-get install -y \
  python3 \
  python3-venv \
  python3-pip \
  mininet \
  openvswitch-switch \
  python3-ryu \
  iproute2 \
  iputils-ping \
  traceroute \
  iperf3 \
  curl

APP_DIR="${APP_DIR:-/opt/mac-tav/mininet-ryu-executor}"
sudo mkdir -p "${APP_DIR}"
sudo chown "$(id -u):$(id -g)" "${APP_DIR}"

python3 -m venv "${APP_DIR}/.venv"
"${APP_DIR}/.venv/bin/pip" install --upgrade pip
"${APP_DIR}/.venv/bin/pip" install -r "${APP_DIR}/requirements.txt"

echo "Install example finished. Copy application files and install the systemd template manually."
